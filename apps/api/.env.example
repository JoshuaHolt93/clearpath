# ClearPath API — production environment template.
# Copy the VALUES into the Railway service variables; never commit real secrets.

# --- Core ---------------------------------------------------------------
CLEARPATH_ENV=production
# Railway Postgres: use the plugin's connection string, but note the driver
# prefix must be `postgresql+psycopg://` (not plain `postgres://`).
DATABASE_URL=postgresql+psycopg://USER:PASSWORD@HOST:5432/DBNAME
# Stable, >=32 chars. Rotating this invalidates all sessions.
# The SOC2 CC4.1-PROD-SECRET control fails if this is missing/weak in production.
SECRET_KEY=

# --- Encryption -----------------------------------------------------------
# Generate fresh Fernet keys for this app (the cutover starts from an empty
# database, so no pre-existing ciphertext has to stay readable):
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Store them durably at creation time. Once this app has written data, rotating
# or losing either key makes the affected values permanently undecryptable.
# NOTE: if you ever decide to migrate the old Flask data in after all, you must
# instead reuse that app's original keys verbatim.
CUSTOMER_DATA_ENCRYPTION_KEY=
PLAID_TOKEN_ENCRYPTION_KEY=

# --- HTTPS / security (SOC2 CC4.1-HTTPS control) -------------------------
FORCE_HTTPS=true
SESSION_COOKIE_SECURE=true
MFA_REQUIRED=true
EXPOSE_DEV_TOKENS=false

# --- Web app URL (invite links, Stripe/Plaid redirect defaults) ----------
WEB_APP_URL=https://your-domain.com

# --- Plaid ---------------------------------------------------------------
PLAID_CLIENT_ID=
PLAID_SECRET=
PLAID_ENV=production
PLAID_WEBHOOK_SECRET=
PLAID_REDIRECT_URI=https://your-domain.com/plaid/oauth
PLAID_WEBHOOK_URL=https://your-domain.com/v1/webhooks/plaid

# --- Email (household invites, MFA email codes, password reset) ----------
TRANSACTIONAL_EMAIL_FROM=
RESEND_API_KEY=
# ...or SMTP instead of Resend:
# MAIL_SERVER=
# MAIL_PORT=587
# MAIL_USERNAME=
# MAIL_PASSWORD=
# MAIL_USE_TLS=true
# MAIL_DEFAULT_SENDER=

# --- Billing (only when launching paid plans) ----------------------------
BILLING_ENABLED=false
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_BASIC_PRICE_ID=
STRIPE_PLUS_PRICE_ID=
STRIPE_PREMIUM_PRICE_ID=
STRIPE_SUCCESS_URL=https://your-domain.com/settings
STRIPE_CANCEL_URL=https://your-domain.com/billing
STRIPE_PORTAL_RETURN_URL=https://your-domain.com/settings

# --- MFA push (optional, Duo) --------------------------------------------
MFA_PUSH_PROVIDER=none
# DUO_CLIENT_ID=
# DUO_CLIENT_SECRET=
# DUO_API_HOSTNAME=
# DUO_REDIRECT_URI=

# --- AI planner (optional; features are plan-gated) ----------------------
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# GOOGLE_AI_API_KEY=
