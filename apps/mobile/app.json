{
  "expo": {
    "name": "ClearPath Finance",
    "slug": "clearpath-finance",
    "scheme": "clearpath",
    "version": "0.0.1",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.clearpathfinance.app"
    },
    "android": {
      "package": "com.clearpathfinance.app",
      "adaptiveIcon": {
        "backgroundColor": "#2d6cdf"
      }
    },
    "plugins": [
      "expo-router",
      "expo-secure-store"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "clearpathApiUrl": "http://127.0.0.1:8000"
    }
  }
}
